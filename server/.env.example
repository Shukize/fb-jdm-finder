# ---- JDM Finder API — environment ----
# Copy to .env for local dev (server/.env is gitignored). On Render, set these
# as the service's Environment Variables instead.

# Neon Postgres connection string (Dashboard → your project → Connection Details
# → "Connection string", the pooled one). Must include ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Apify — the real Facebook Marketplace data source.
# 1) Make a free account at https://apify.com
# 2) Pick a "Facebook Marketplace" actor in the Apify Store and copy its ID
#    (the owner~actor-name shown on the actor page).
# 3) Copy your API token from Settings → Integrations.
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
APIFY_ACTOR=owner~facebook-marketplace-scraper

# Shared secret required to trigger POST/GET /api/refresh. Pick anything long.
REFRESH_SECRET=change-me-to-a-long-random-string

# Allowed CORS origins for the public read API. "*" is fine for a public,
# read-only listings API. To lock it to your site, set e.g.:
# CORS_ORIGINS=https://shukize.github.io
CORS_ORIGINS=*

# ---- optional tuning ----
# How often the server auto-scrapes (cron syntax). Default: every 6 hours.
REFRESH_CRON=0 */6 * * *
# Which cars to scrape (comma-separated keys, or "all"). Keys:
# rx7,gt86,240sx,r32,supra,corolla,celica,talon,eclipsegsx
SCRAPE_MODELS=all
# Which countries to scrape (comma-separated codes). Each extra country
# multiplies Apify credit usage. Default when unset: US only.
# Codes: US,CA,GB,AU,JP,DE
SCRAPE_COUNTRIES=US
# Max listings per model/country actor run.
SCRAPE_MAX_ITEMS=40
# How many actor runs to fire in parallel.
SCRAPE_CONCURRENCY=2
# Drop live listings not seen for this many days (sold/removed). 0 = never.
SCRAPE_PRUNE_DAYS=14
# Per-actor-run timeout in seconds.
SCRAPE_RUN_TIMEOUT=120
