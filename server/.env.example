# ---- JDM Finder API — environment ----
# Copy to .env for local dev (server/.env is gitignored). On Render, set these
# as the service's Environment Variables instead.

# Neon Postgres connection string (Dashboard → your project → Connection Details
# → "Connection string", the pooled one). Must include ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ── Primary source: Facebook Marketplace via Apify ──
# Apify's free plan gives $5 of credit every month (resets monthly), which the
# default 12-hour, US-only scrape stays within — so this is effectively free.
# 1) Make a free account at https://apify.com
# 2) Recommended actor: apify~facebook-marketplace-scraper (the server builds the
#    Marketplace search-URL input it expects). Other FB Marketplace actors also
#    work via the fallback keyword keys in server/scraper.js buildInput().
# 3) Copy your API token from Settings → Integrations.
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
APIFY_ACTOR=apify~facebook-marketplace-scraper

# ── Free fallback source: eBay Motors via the Browse API ──
# Optional but recommended: real car listings for $0 (free tier ~5,000 calls/day),
# so the site still shows cars if Apify's monthly $5 is spent. Create a free eBay
# developer account → make a PRODUCTION keyset → copy App ID + Cert ID:
#   https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=YourApp-xxxx-PRD-xxxxxxxxx-xxxxxxxx
EBAY_CLIENT_SECRET=PRD-xxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxx

# Shared secret required to trigger POST/GET /api/refresh. Pick anything long.
REFRESH_SECRET=change-me-to-a-long-random-string

# Allowed CORS origins for the public read API. "*" is fine for a public,
# read-only listings API. To lock it to your site, set e.g.:
# CORS_ORIGINS=https://shukize.github.io
CORS_ORIGINS=*

# ---- optional tuning ----
# How often the server auto-scrapes (cron syntax). Default: every 12 hours,
# which keeps the Apify (Facebook) scrape inside the free $5/month credit.
# Scrape more often only if you've added Apify credit or rely on free eBay.
REFRESH_CRON=0 */12 * * *
# Which cars to scrape (comma-separated keys, or "all"). Keys:
# rx7,gt86,240sx,r32,supra,corolla,celica,talon,eclipsegsx
SCRAPE_MODELS=all
# Which countries to scrape (comma-separated codes). Each extra country
# multiplies Apify credit usage. Default when unset: US only.
# Codes: US,CA,GB,AU,JP,DE
SCRAPE_COUNTRIES=US
# Max listings per model/country actor run.
SCRAPE_MAX_ITEMS=40
# How many actor runs to fire in parallel.
SCRAPE_CONCURRENCY=2
# Drop live listings not seen for this many days (sold/removed). 0 = never.
SCRAPE_PRUNE_DAYS=14
# Per-actor-run timeout in seconds.
SCRAPE_RUN_TIMEOUT=120
